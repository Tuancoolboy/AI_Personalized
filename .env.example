# ============================================
# AI20K Project — Environment Variables
# ============================================
# Copy this file to .env (Python backend) hoặc .env.local (Next.js app) và điền giá trị.
# NEVER commit .env or .env.local to git!

# ---- LLM Configuration ----
# Choose one or both providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=

# Default model
DEFAULT_MODEL=claude-sonnet-4-20250514
# DEFAULT_MODEL=gpt-4o

# ---- Database (Python backend / LangGraph) ----
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# For SQLite (development):
# DATABASE_URL=sqlite:///./data/app.db

# ---- Vector Store ----
CHROMA_PERSIST_DIR=./data/chroma
# Or Pinecone:
# PINECONE_API_KEY=
# PINECONE_ENVIRONMENT=

# ---- App Config (Python backend) ----
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- LangSmith (AI Logs — Deliverable #4) ----
LANGCHAIN_API_KEY=your-langsmith-key-here
LANGCHAIN_PROJECT=ai20k-agent
LANGCHAIN_TRACING_V2=true

# ---- Logging ----
LOG_LEVEL=INFO

# ---- AI Hook Logging (provided by instructor — KHÔNG đổi giá trị) ----
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=f3p1dEOhD_z8qjjtbeCtb2t9ASMEliz-4juZfWe3ZPgCtPZp-LjWthBfeNU8d5dP
AI_LOG_DIR=.ai-log

# ============================================
# MVP APP — Next.js 16 (frontend)
# ============================================
# Copy file này thành .env.local (KHÔNG commit) và điền keys thật.
# Trên Vercel: set qua dashboard (Settings → Environment Variables).
# Xem docs/ops/supabase-setup.md để lấy Supabase keys.

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=  # Khuyến nghị từ Supabase dashboard mới
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=    # BÍ MẬT — chỉ server, không xuất hiện trong client bundle

# ---- Supabase CLI (migration auto-sync trước npm run dev) ----
# Lấy token: https://supabase.com/dashboard/account/tokens
# Database password: Project Settings → Database
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_DB_PASSWORD=
# SUPABASE_PROJECT_REF=        # Tuỳ chọn; mặc định suy từ NEXT_PUBLIC_SUPABASE_URL
# SUPABASE_DB_SYNC=false       # Tắt auto push migration trước dev/start
# SUPABASE_DB_SYNC_STRICT=true # Fail dev nếu chưa link CLI

# ---- Frontend ↔ Backend bridge ----
# NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- OpenAI cho /tro-ly chat AI (Next.js side) ----
# Khi có OPENAI_API_KEY → /api/chat dùng OpenAI streaming. Thiếu key → fallback canned.
OPENAI_MODEL=gpt-4o-mini       # Mô hình rẻ; có thể đổi gpt-4o khi cần chất lượng cao hơn
RATE_LIMIT_PER_DAY=30          # Số lượt chat tối đa/user/ngày (CLAUDE.md §11)
