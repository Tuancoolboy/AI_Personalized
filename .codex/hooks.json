{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/_pyrun.sh scripts/log_hook.py --tool=codex",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/_pyrun.sh scripts/log_hook.py --tool=codex",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
